NODE_ENV=production
PORT=3000

# Set your public origin (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://hutaroblog.com

# Future sensor API auth secret (prepare now, use later)
SENSOR_API_KEY=replace-with-long-random-secret

# Recommended: persist access counter outside app deploy directory
ACCESS_COUNTER_STORE_PATH=/opt/blog/shared/access-counter.json

# Set to 1 only after HTTPS is enabled.
# CSP_UPGRADE_INSECURE_REQUESTS=1
