{
  "name": "blog_starter_20260315",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium",
    "lint": "eslint",
    "publish": "npm run lint && npm run build",
    "dev:minimal": "THEME_VARIANT=minimal npm run dev",
    "dev:labnote": "THEME_VARIANT=labnote npm run dev",
    "dev:magazine": "THEME_VARIANT=magazine npm run dev",
    "preview": "npm run build && npm run start",
    "security": "npm audit --audit-level=high",
    "publish:secure": "npm run lint && npm run test && npm run build && npm run security",
    "assets:optimize": "node scripts/optimize-assets.mjs",
    "assets:optimize:dry": "node scripts/optimize-assets.mjs --dry-run",
    "assets:resize": "node scripts/optimize-assets.mjs",
    "ops:sanity": "./scripts/ops-sanity.sh",
    "ops:validate-env:example": "./scripts/validate-env-file.sh --file env.production.example --required \"NODE_ENV PORT NEXT_PUBLIC_SITE_URL SENSOR_API_KEY\"",
    "security:smoke": "./scripts/security-smoke.sh",
    "ops:status": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} ./scripts/remote-status.sh",
    "ops:recover": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} ./scripts/remote-recover.sh",
    "ops:security-status": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} ./scripts/remote-security-status.sh",
    "ops:security-audit": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} ./scripts/remote-security-audit.sh",
    "ops:security-audit:json": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} AUDIT_FORMAT=json ./scripts/remote-security-audit.sh",
    "ops:security-audit:report": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} ./scripts/security-audit-report.sh",
    "ops:security-audit:summary": "node scripts/security-audit-summary.mjs --input-dir=./audit-reports --max-failed=0",
    "ops:security-audit:summary:md": "node scripts/security-audit-summary.mjs --input-dir=./audit-reports --output=./audit-reports/latest-summary.md --max-failed=0",
    "ops:security-audit:regression": "node scripts/security-audit-regression.mjs --input-dir=./audit-reports --max-new-failures=0",
    "ops:security-audit:daily": "TARGET_HOST=${TARGET_HOST:?TARGET_HOST is required} TARGET_USER=${TARGET_USER:-deploy} ./scripts/security-audit-daily.sh"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
